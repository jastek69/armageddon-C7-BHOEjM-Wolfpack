# Route 53 failover config
# copy this to terraform.tfvars and fill in values

aws_profile = "default"

# your domain
domain_name    = "lab3.yourdomain.com"
hosted_zone_id = "Z1234567890ABC"

# tokyo ALB (from tokyo terraform output)
tokyo_alb_dns     = "lab3-tokyo-alb-2005384345.ap-northeast-1.elb.amazonaws.com"
tokyo_alb_zone_id = "Z14GRHDCWA56QT"  # ALB zone ID for ap-northeast-1

# osaka ALB (from osaka terraform output after deploy)
osaka_alb_dns     = ""  # fill after osaka deploy
osaka_alb_zone_id = "Z5LXEXXYW11ES"   # ALB zone ID for ap-northeast-3
